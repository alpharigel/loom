{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Loom",
  "version": "0.1.0",
  "identifier": "dev.loom.app",
  "build": {
    "frontendDist": "splash"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Loom",
        "url": "index.html",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#0e0e10"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Loom — agent project workspace manager",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../server.js",
      "../package.json",
      "../public/**/*"
    ]
  }
}
